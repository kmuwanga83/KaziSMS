# Server Configuration
NODE_ENV=development
PORT=3001

# SMSC Server Configuration
SMSC_HOST=0.0.0.0
SMSC_PORT=2775
ADMIN_PORT=3002

# Default Admin Client (auto-created)
DEFAULT_SYSTEM_ID=kazisys_admin
DEFAULT_PASSWORD=admin123

# Webhook Configuration (optional)
WEBHOOK_URL=
WEBHOOK_SECRET=kazisms-webhook-secret-2024

# SMPP Upstream Configuration (when you get credentials)
# SMPP_HOST=smpp.esmsafrica.com
# SMPP_PORT=2775
# SMPP_SYSTEM_ID=your_system_id
# SMPP_PASSWORD=your_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
